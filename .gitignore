/target
__pycache__/
*.pyc
.venv/
# Python wheel/sdist build output — ANCHORED to the build dir so it does not
# also match Rust source module directories named `dist` (e.g.
# crates/tsecon-stats/src/dist/, which is real source that must be committed).
/bindings/python/dist/
*.so
*.egg-info/
.pytest_cache/
.DS_Store
.claude/

# mkdocs build output
/site/

# Coverage artifacts (see .coveragerc; the config itself is committed)
.coverage
.coverage.*
htmlcov/
